library(tidyverse)
install.packages('eulerr')
install.packages('tidyverse')
library(tidyverse)
library(eulerr)
library(ggplot2)
library(gridExtra)
working_dir <- "C:/docs/proteomics_project/smprot_analysis/"
setwd(working_dir)
smprot_file  <- "spliced_all_results.tsv"   # або spliced_smprot_hits.tsv
openprot_file <- "openprot_all_results.tsv"
cat("Loading datasets...\n")
df_sm <- read_delim(smprot_file, delim = "\t", show_col_types = FALSE)
df_op <- read_delim(openprot_file, delim = "\t", show_col_types = FALSE)
# Створюємо логічні вектори (True/False) для наявності хітів у кожному спектрі
# Припускаємо, що унікальним ключем є комбінація 'Spectrum' та 'Peptide'
sm_status <- df_sm %>%
select(Spectrum, Peptide, Class, `Peptide Length`, Hyperscore, SmProt_Hits) %>%
mutate(In_SmProt = (SmProt_Hits != "No Hit"))
op_status <- df_op %>%
select(Spectrum, OpenProt_Hits) %>%
mutate(In_OpenProt = (OpenProt_Hits != "No Hit"))
# Об'єднуємо дві таблиці в одну фінальну для статистики
master_df <- inner_join(sm_status, op_status, by = "Spectrum")
total_peptides <- nrow(master_df)
cat("Total non-canonical peptides to analyze:", total_peptides, "\n")
only_sm <- sum(master_df$In_SmProt & !master_df$In_OpenProt)
only_op <- sum(!master_df$In_SmProt & master_df$In_OpenProt)
both    <- sum(master_df$In_SmProt & master_df$In_OpenProt)
none    <- sum(!master_df$In_SmProt & !master_df$In_OpenProt)
cat("Only SmProt:", only_sm, "\nOnly OpenProt:", only_op, "\nBoth:", both, "\nNone:", none, "\n")
# Формуємо комбінації для пакету eulerr
fit_data <- c(
"SmProt" = only_sm,
"OpenProt" = only_op,
"SmProt&OpenProt" = both
)
euler_diagram <- euler(fit_data)
# Додаємо групу для зручної візуалізації
master_df <- master_df %>%
mutate(Hit_Category = case_when(
In_SmProt & In_OpenProt ~ "Both Databases",
In_SmProt ~ "SmProt Only",
In_OpenProt ~ "OpenProt Only",
TRUE ~ "Unmapped (Novel)"
))
# Статистика 1: Розподіл Hyperscore (Якість спектрів для знайдених і незнайдених)
plot_hyperscore <- ggplot(master_df, aes(x = Hit_Category, y = Hyperscore, fill = Hit_Category)) +
geom_boxplot(alpha = 0.7, outlier.color = "red", outlier.shape = 16) +
geom_jitter(width = 0.2, alpha = 0.3, size = 1) +
theme_minimal() +
labs(title = "MS/MS Identification Quality across Databases",
x = "Database Hit Status",
y = "Hyperscore") +
theme(legend.position = "none",
plot.title = element_text(face = "bold", size = 12)) +
scale_fill_brewer(palette = "Set2")
# Статистика 2: Довжина пептидів (Чи є різниця у довжині між базами)
plot_length <- ggplot(master_df, aes(x = `Peptide Length`, fill = Hit_Category)) +
geom_bar(position = "dodge", alpha = 0.8) +
theme_minimal() +
labs(title = "Peptide Length Distribution",
x = "Peptide Length (aa)",
y = "Spectrum Count",
fill = "Status") +
theme(plot.title = element_text(face = "bold", size = 12)) +
scale_fill_brewer(palette = "Set2")
cat("\nSaving high-quality plots...\n")
# 1. Збереження Діаграми Ейлера (TIFF)
tiff("plot_euler_diagram.tiff", width = 2400, height = 2000, res = 300, compression = "lzw")
plot(euler_diagram,
quantities = list(type = c("counts", "percent"), font = 2),
fills = c("#66c2a5", "#fc8d62"),
alpha = 0.6,
labels = list(font = 2, cex = 1.2),
main = paste0("Overlap of Non-Canonical Peptides (Total N = ", total_peptides, ")"))
dev.off()
# 2. Збереження Діаграми Ейлера (PDF для статей/вектору)
pdf("plot_euler_diagram.pdf", width = 8, height = 7)
plot(euler_diagram,
quantities = list(type = c("counts"), font = 2),
fills = c("#66c2a5", "#fc8d62"),
alpha = 0.6,
main = paste0("Overlap of Non-Canonical Peptides (Total N = ", total_peptides, ")"))
dev.off()
# 3. Збереження додаткової статистики в один комбінований TIFF
combined_stats <- grid.arrange(plot_hyperscore, plot_length, ncol = 2)
ggsave("plot_proteomics_statistics.tiff",
plot = combined_stats,
device = "tiff",
path = working_dir,
width = 12,
height = 6,
dpi = 300,
compression = "lzw")
# 4. Збереження додаткової статистики в один комбінований PDF
ggsave("plot_proteomics_statistics.pdf",
plot = combined_stats,
device = "pdf",
path = working_dir,
width = 12,
height = 6)
cat("Done! All high-resolution files saved successfully to your folder.\n")
